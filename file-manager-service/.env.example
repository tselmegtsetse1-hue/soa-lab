PORT=3001

# SOAP (same as Lab06 JSON service)
SOAP_WSDL_URL=http://localhost:4000/wsdl?wsdl

# DigitalOcean Spaces — API → Spaces Keys (never commit real values)
# Endpoint example: https://sgp1.digitaloceanspaces.com
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_REGION=sgp1
SPACES_BUCKET=your-bucket-name

# Access Key + Secret from DO API → Tokens / Spaces access keys
SPACES_KEY=
SPACES_SECRET=

# Optional: public URL base if CDN/custom domain (otherwise built from endpoint + bucket)
# SPACES_PUBLIC_BASE=https://your-bucket.sgp1.cdn.digitaloceanspaces.com
