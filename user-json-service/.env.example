PORT=3000
SOAP_WSDL_URL=http://localhost:4000/wsdl?wsdl

# Local profile DB (Lab 06) — ашиглана хэрэв доорх cloud тохиргоо байхгүй бол
DB_PATH=./db/profile.db

# Lab 07 — Cloud PostgreSQL (DigitalOcean Managed DB гэх мэт)
# Сонголт A: нэг мөр (DO "Connection string" хуулна)
# DATABASE_URL=postgresql://doadmin:PASSWORD@private-host.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Сонголт B: даалгаврын жишээ — DB_USERNAME, DB_PASSWORD (энэ нэрээр App Platform-д оруулна)
# DB_HOST=your-db-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_USERNAME=doadmin
# DB_PASSWORD=your_password
# DB_NAME=defaultdb

# SSL идэвхгүй бол (зөвхөн local test): PGSSLMODE=disable эсвэл DB_SSL=false
